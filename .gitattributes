# Ensure consistent line endings across platforms
* text=auto

# Shell scripts must use LF (Unix) line endings
*.sh text eol=lf
*.bash text eol=lf

# Python files should use LF
*.py text eol=lf

# Launch files should use LF 
*.launch text eol=lf
*.launch.py text eol=lf

# Config files should use LF
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.xml text eol=lf

# ROS-specific files
*.msg text eol=lf
*.srv text eol=lf
*.action text eol=lf
*.urdf text eol=lf
*.xacro text eol=lf

# Markdown and documentation
*.md text eol=lf
*.txt text eol=lf

# Dockerfile
Dockerfile* text eol=lf

# Makefile
Makefile text eol=lf
*.mk text eol=lf